{
  "manifest_version": 3,
  "key": "",
  "name": "__MSG_extName__",
  "version": "0.5.14",
  "description": "__MSG_extDesc__",
  "default_locale": "zh_CN",
  "icons": {
    "128": "images/github_512.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.github.com/*"],
      "js": [
        "src/utils/i18n.js",
        "src/content/api.js",
        "src/content/utils.js",
        "src/content/features.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["_locales/*/*.json"],
      "matches": ["*://*.github.com/*"]
    }
  ],
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.github.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "GithubRemark",
    "default_icon": {
      "19": "images/github.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "devtools_page": "src/options/options.html"
}